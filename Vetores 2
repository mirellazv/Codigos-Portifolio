#include <iostream>
using namespace std;
int main()
{
 int A[3] = {1,2,3};
 int B[3] = {5,6,7};
 int C[3] = {9,10,11};
 int D[3];

 for (int i = 0; i < 3; i++) {
 D[i] = A[i] + B[i]+ C[i];
 cout << D[i] << " ";
}
 return 0;
}

