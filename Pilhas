#include <iostream>
using namespace std;
int main() {
int laranjasBase = 5;
double precoBase = 10;
int n;
cout << "Quantas laranjas voce deseja comprar? ";
cin >> n;
double precoUnitario = precoBase / laranjasBase;
double precoTotal = n * precoUnitario;
cout << "Se 5 laranjas custam 10 reais, cada uma custa " << precoUnitario << " reais." <<
endl;
cout << "Logo, " << n << " laranjas custarao: R$ " << precoTotal << endl;
return 0;
}

